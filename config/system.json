{
  "can": {
    "links": [
      {
        "can_index": 0,
        "name": "can0_pcu",
        "role": "periodic_tx_rx",
        "enable": true,

        "protocol": {
          "type": "emu_pcu_v1",
          "ids": {
            "emu_ctrl":   "0x1801A0E0",
            "emu_status": "0x1802A0E0",
            "pcu_status": "0x1801EFA0"
          }
        },

        "tx": {
          "enable": true,
          "interval_ms": 200,
          "send_ctrl": true,
          "send_status": true,

          "ctrl_enable_default": "0x01",
          "plug_default": "0x00",
          "estop_default": "0x00",
          "batt1_estop_default": "0x00",
          "batt2_estop_default": "0x00"
        },

        "rx": {
          "enable": true,
          "timeout_ms": 1000,
          "require_heartbeat_increment": false
        }
      },
      {
        "can_index": 1,
        "name": "can1_pcu",
        "role": "periodic_tx_rx",
        "enable": true,

        "protocol": {
